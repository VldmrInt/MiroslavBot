# Скопируйте этот файл в .env и заполните значения

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Прокси для подключения бота к Telegram API.
# Актуально в России, где Telegram заблокирован.
#
# Если не задан — бот автоматически использует первый SOCKS5-прокси
# из списка default в proxies/users.json.
#
# Можно задать явно, например:
#   BOT_PROXY_URL=socks5://user:pass@45.150.37.167:12335
#   BOT_PROXY_URL=http://45.150.37.167:3128
BOT_PROXY_URL=

# Telegram user ID администратора бота.
# Только этот пользователь может использовать команду /broadcast.
# Узнать свой ID можно у бота @userinfobot.
ADMIN_ID=
